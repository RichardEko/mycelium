{
  "name": "mycelium-ts",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Mycelium gossip mesh",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["gossip", "distributed", "mesh", "p2p"],
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "eventsource-parser": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.json"
      }
    }
  }
}
