# Copy this file to .env and fill in your API key before running.
#
#   cp docker/.env.example docker/.env

# ── Required ──────────────────────────────────────────────────────────────────

# Your OpenAI API key (or any OpenAI-compatible provider)
OPENAI_API_KEY=sk-your-key-here

# ── Optional ──────────────────────────────────────────────────────────────────

# OpenAI-compatible endpoint (default: OpenAI production)
# Ollama example: http://host.docker.internal:11434/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model name (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Override the task the LLM will work on
# DEMO_TASK=What is the current weather in Tokyo? Also, what is the speed of light in metres per second divided by the number of seconds in a day?
