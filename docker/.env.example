# No API key required — this demo uses Ollama (local LLM).
#
# Optional overrides:

# Which Ollama model to use (default: llama3.2)
# OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (useful if running Ollama outside Docker)
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Port for the browser chat UI on the llm container (default: 8080)
# CHAT_PORT=8080
