/target
.DS_Store

# Internal strategy docs (private — go-to-market, compliance, v30 integration, …)
docs/internal/
docs/commercial.html

# Papers & presentations are public: their sources (.tex/.md/.bib + figure/data
# files) are tracked under docs/publications/. Only whole-paper RENDERED HTML is
# excluded — it is derived from the source and rots immediately (the same rule
# that retired docs/readme.html and docs/roadmap.html). The presentation deck
# (presentation.html) is itself the source, so it is NOT excluded.
docs/publications/arxiv/**/*.html
docs/publications/paper.html

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/

# Community example runtime artifacts
examples/community/logs/

# Demo runtime artifacts (pids + logs from examples/*/demo.sh runs)
examples/*/logs/

# LaTeX render artifacts (PDFs are published to Zenodo/arXiv, not tracked)
docs/publications/arxiv/**/*.aux
docs/publications/arxiv/**/*.bbl
docs/publications/arxiv/**/*.out
docs/publications/arxiv/**/*.log
docs/publications/arxiv/**/main.pdf
docs/publications/arxiv/*.aux
docs/publications/arxiv/*.bbl
docs/publications/arxiv/*.out
docs/publications/arxiv/*.log
docs/publications/arxiv/main.pdf
